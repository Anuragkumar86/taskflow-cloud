# File: taskflow-cloud/backend/.env.example
# This is a template. Copy to .env and fill in real values.

# Server

PORT=5000
NODE_ENV=development

# Database (PostgreSQL - RDS in production)
DATABASE_URL=postgresql://taskflow_user:localpassword@localhost:5432/taskflow

DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow_user
DB_PASSWORD=your_password_here

# JWT Secret (make this a long random string)
JWT_SECRET=fstweAsDdDfdeFGEWEfrrt
JWT_EXPIRES_IN=7d



# Redis (ElastiCache in production)
REDIS_URL=redis://localhost:6379

REDIS_HOST=localhost
REDIS_PORT=6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000